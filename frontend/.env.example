# Use /api in development (Vite proxies to the backend). For production, set your deployed API URL.
VITE_API_BASE_URL=/api
VITE_NOMINATIM_BASE_URL=https://nominatim.openstreetmap.org
VITE_OSRM_BASE_URL=https://router.project-osrm.org
VITE_OPENTRIPMAP_BASE_URL=https://api.opentripmap.com/0.1/en/places
# Optional. OpenTripMap has a free tier but requires a key. If empty, the app uses Wikimedia's no-key API.
VITE_OPENTRIPMAP_API_KEY=
