PORT=5000
NODE_ENV=development
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-url>/india-tourism-explorer
CLIENT_URL=http://localhost:5173
JWT_SECRET=replace_with_a_long_random_secret
# Optional. If empty, weather uses the free Open-Meteo API automatically.
OPENWEATHER_API_KEY=
JWT_EXPIRES_IN=7d
JWT_COOKIE_EXPIRES_DAYS=7
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
